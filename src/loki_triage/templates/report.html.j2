<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ config.get('report_title', 'Loki Triage Report') }} - {{ period }}</title>
  <style>
    :root {
      --primary: {{ config.get('primary_color', '#0b3954') }};
      --secondary: {{ config.get('secondary_color', '#087e8b') }};
      --accent: {{ config.get('accent_color', '#bfd7ea') }};
      --ink: #10212b;
      --muted: #58707f;
      --line: #d7e1e7;
      --paper: #f7fafc;
      --white: #ffffff;
    }
    @page {
      size: A4;
      margin: 14mm;
    }
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--paper);
      font-family: "Source Serif 4", Georgia, serif;
      font-size: 12px;
      line-height: 1.45;
    }
    h1, h2, h3, h4 {
      margin: 0;
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      line-height: 1.15;
    }
    .page {
      display: block;
    }
    .hero {
      position: relative;
      overflow: hidden;
      padding: 22px 24px 20px;
      background: linear-gradient(135deg, var(--primary), #114b5f 58%, var(--secondary));
      color: var(--white);
      border-radius: 14px;
    }
    .hero::after {
      content: "";
      position: absolute;
      inset: auto -70px -70px auto;
      width: 180px;
      height: 180px;
      background: radial-gradient(circle, rgba(255,255,255,0.28), rgba(255,255,255,0));
      border-radius: 50%;
    }
    .hero-top {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
    }
    .hero-meta {
      min-width: 220px;
      text-align: right;
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      font-size: 11px;
    }
    .hero h1 {
      font-size: 28px;
      margin-bottom: 6px;
    }
    .hero p {
      margin: 0;
      max-width: 620px;
      font-size: 13px;
      opacity: 0.92;
    }
    .hero-logo {
      max-width: 120px;
      max-height: 46px;
      margin-bottom: 10px;
      object-fit: contain;
      background: rgba(255,255,255,0.94);
      padding: 6px 8px;
      border-radius: 8px;
    }
    .section {
      margin-top: 18px;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 16px 18px;
      break-inside: avoid;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 12px;
      align-items: baseline;
    }
    .section-title {
      font-size: 16px;
      color: var(--primary);
    }
    .section-subtitle {
      color: var(--muted);
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      font-size: 11px;
    }
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .kpi {
      padding: 14px;
      border-radius: 10px;
      background: linear-gradient(180deg, #ffffff, #f2f7fa);
      border: 1px solid var(--line);
    }
    .kpi-label {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .kpi-value {
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      font-weight: 700;
      font-size: 28px;
      color: var(--primary);
    }
    .note {
      margin-top: 10px;
      padding: 10px 12px;
      border-left: 4px solid var(--secondary);
      background: #f3fbfc;
      color: #20404e;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }
    th, td {
      padding: 8px 9px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
      text-align: left;
    }
    th {
      color: var(--muted);
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .pill {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 999px;
      font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      font-size: 10px;
      font-weight: 700;
      white-space: nowrap;
    }
    .severity-ALERT, .priority-critical, .disposition-true_positive {
      background: #ffe3e0;
      color: #8a1f17;
    }
    .severity-WARNING, .priority-high, .disposition-needs_followup {
      background: #fff1d6;
      color: #8a5a00;
    }
    .severity-ERROR, .priority-medium {
      background: #f5ebff;
      color: #5d3683;
    }
    .severity-NOTICE, .priority-low, .disposition-false_positive {
      background: #e6f4ff;
      color: #0a5381;
    }
    .severity-INFO, .priority-info, .disposition-unreviewed, .disposition-expected_benign {
      background: #edf3f6;
      color: #48616f;
    }
    .appendix-host {
      margin-top: 16px;
      padding-top: 12px;
      border-top: 1px solid var(--line);
    }
    .appendix-host:first-of-type {
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
    }
    .appendix-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 10px;
    }
    .finding-card {
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fcfdfe;
      break-inside: avoid;
    }
    .finding-card h4 {
      font-size: 13px;
      margin-bottom: 8px;
      color: var(--primary);
    }
    .meta-row {
      margin-top: 4px;
      color: var(--muted);
      font-size: 11px;
    }
    .summary-list {
      margin: 0;
      padding-left: 18px;
    }
    .summary-list li {
      margin-bottom: 6px;
    }
    .mono {
      font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
      word-break: break-all;
    }
    .footnote {
      margin-top: 18px;
      color: var(--muted);
      font-size: 10px;
      text-align: right;
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="hero">
      <div class="hero-top">
        <div>
          <div class="section-subtitle">{{ config.get('organization_name', 'Organization') }}</div>
          <h1>{{ config.get('report_title', 'Loki Threat Triage') }}</h1>
          <p>{{ config.get('subtitle', 'Executive summary and technical appendix') }}</p>
        </div>
        <div class="hero-meta">
          {% if config.get('logo_path') %}
          <img class="hero-logo" src="{{ config.get('logo_path') }}" alt="Logo">
          {% endif %}
          <div><strong>Period:</strong> {{ period }}</div>
          <div><strong>Generated:</strong> {{ generated_at }}</div>
          <div><strong>Runs:</strong> {{ run_ids|length }}</div>
          <div><strong>Report ID:</strong> {{ report_id }}</div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Executive Summary</h2>
        <div class="section-subtitle">Management-facing overview</div>
      </div>
      <div class="kpi-grid">
        <div class="kpi">
          <span class="kpi-label">Hosts Covered</span>
          <span class="kpi-value">{{ dataset.kpis.get('host_count', 0) }}</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">Unique Findings</span>
          <span class="kpi-value">{{ dataset.kpis.get('finding_count', 0) }}</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">Needs Follow-up</span>
          <span class="kpi-value">{{ dataset.kpis.get('needs_followup_count', 0) }}</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">True Positives</span>
          <span class="kpi-value">{{ dataset.kpis.get('true_positive_count', 0) }}</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">False Positives</span>
          <span class="kpi-value">{{ dataset.kpis.get('false_positive_count', 0) }}</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">Unreviewed</span>
          <span class="kpi-value">{{ dataset.kpis.get('unreviewed_count', 0) }}</span>
        </div>
      </div>
      <div class="note">{{ config.get('disclaimer', '') }}</div>
      <ul class="summary-list">
        <li>New findings in scope: {{ dataset.kpis.get('new_count', 0) }}</li>
        <li>Persisting findings in rescans: {{ dataset.kpis.get('persisting_count', 0) }}</li>
        <li>Reopened findings after prior absence: {{ dataset.kpis.get('reopened_count', 0) }}</li>
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Top Hosts</h2>
        <div class="section-subtitle">Highest occurrence counts in scope</div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Host</th>
            <th>Occurrences</th>
          </tr>
        </thead>
        <tbody>
          {% if dataset.top_hosts %}
            {% for row in dataset.top_hosts %}
            <tr>
              <td>{{ row.host }}</td>
              <td>{{ row.occurrence_count }}</td>
            </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="2">No findings available for this reporting scope.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Priority Findings</h2>
        <div class="section-subtitle">Most recent high-importance items</div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Host</th>
            <th>Finding</th>
            <th>Priority</th>
            <th>Disposition</th>
            <th>State</th>
            <th>VT</th>
          </tr>
        </thead>
        <tbody>
          {% set important = dataset.findings[:15] %}
          {% if important %}
            {% for row in important %}
            <tr>
              <td>{{ row.host }}</td>
              <td>
                <strong>{{ row.title }}</strong>
                <div class="meta-row">{{ row.event_type }}{% if row.event_kind %} / {{ row.event_kind }}{% endif %}</div>
              </td>
              <td><span class="pill priority-{{ row.priority }}">{{ row.priority }}</span></td>
              <td><span class="pill disposition-{{ row.current_disposition }}">{{ row.current_disposition }}</span></td>
              <td>{{ row.state_for_host_run or '-' }}</td>
              <td>
                {% if row.vt_summary %}
                  M={{ row.vt_summary.get('malicious_count', 0) }}, S={{ row.vt_summary.get('suspicious_count', 0) }}
                {% else %}
                  -
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="6">No findings available for this reporting scope.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Recurrent False Positives</h2>
        <div class="section-subtitle">Candidates for upstream Loki suppression review</div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Rule Key</th>
            <th>Occurrences</th>
          </tr>
        </thead>
        <tbody>
          {% if dataset.recurrent_false_positives %}
            {% for row in dataset.recurrent_false_positives %}
            <tr>
              <td class="mono">{{ row.rule_key }}</td>
              <td>{{ row.occurrences }}</td>
            </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="2">No recurrent false positives are currently recorded.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
      <div class="note">{{ config.get('redaction_note', '') }}</div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Technical Appendix</h2>
        <div class="section-subtitle">Grouped by host for analyst follow-up</div>
      </div>
      {% if dataset.appendix %}
        {% for host, items in dataset.appendix.items() %}
        <div class="appendix-host">
          <h3>{{ host }}</h3>
          <div class="appendix-grid">
            {% for row in items %}
            <article class="finding-card">
              <h4>{{ row.title }}</h4>
              <div>
                <span class="pill severity-{{ row.severity }}">{{ row.severity }}</span>
                <span class="pill priority-{{ row.priority }}">{{ row.priority }}</span>
                <span class="pill disposition-{{ row.current_disposition }}">{{ row.current_disposition }}</span>
              </div>
              <div class="meta-row">Seen: {{ row.occurrence_ts }} | State: {{ row.state_for_host_run or '-' }}</div>
              <div class="meta-row">Rule: <span class="mono">{{ row.rule_key }}</span></div>
              {% if row.artifact_path %}
              <div class="meta-row">Artifact: {{ row.artifact_path }}</div>
              {% endif %}
              {% if row.sha256 %}
              <div class="meta-row">SHA256: <span class="mono">{{ row.sha256 }}</span></div>
              {% endif %}
              <div class="meta-row">Source: {{ row.source_path }}:{{ row.source_line_start }}</div>
              {% if row.current_reason %}
              <div class="meta-row">Analyst note: {{ row.current_reason }}</div>
              {% endif %}
              {% if row.vt_summary %}
              <div class="meta-row">VT stats: malicious={{ row.vt_summary.get('malicious_count', 0) }}, suspicious={{ row.vt_summary.get('suspicious_count', 0) }}</div>
              {% endif %}
            </article>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p>No technical findings were available for this reporting scope.</p>
      {% endif %}
    </section>

    <div class="footnote">Generated from immutable Loki evidence and derived triage state.</div>
  </div>
</body>
</html>
